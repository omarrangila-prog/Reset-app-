# RESET environment. Copy to .env.local and fill in.

# --- Session signing secret (REQUIRED so logins survive restarts) ---
# Generate: openssl rand -base64 48
SESSION_SECRET=""

# --- Field encryption key for journal/notes (REQUIRED; keep it SAFE & backed up:
#     if this changes, previously-encrypted entries become unreadable) ---
# Generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=""

# --- SQLite database file location (persistent disk) ---
# Local default: ./data/reset.db. On Railway/Render, point this at a mounted volume,
# e.g. SQLITE_PATH="/data/reset.db"
SQLITE_PATH="./data/reset.db"

# --- Free AI coach (Groq). Optional — without it the coach uses safe scripted replies ---
# Free key: https://console.groq.com
GROQ_API_KEY=""
