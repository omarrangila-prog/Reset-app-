# RESET frontend environment — TEMP / no-database demo mode.
# Copy to .env.local. Everything here is OPTIONAL: the app runs with zero setup
# (ephemeral in-memory data + safe scripted coach). Set these for real use.

# --- Free AI coach (Groq) ---
# Free signup: https://console.groq.com  → create an API key.
# Without it, the coach uses built-in safe scripted responses.
GROQ_API_KEY=""
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL="llama-3.3-70b-versatile"

# --- Session signing secret (recommended in production) ---
# Without it, an ephemeral secret is generated (sessions reset on restart).
# Generate: openssl rand -base64 48
SESSION_SECRET=""

# --- Field encryption key for journal/notes (recommended in production) ---
# Without it, an ephemeral key is generated (data is in-memory anyway).
# Generate: openssl rand -base64 32
APP_ENCRYPTION_KEY=""

# NOTE: This build uses a TEMPORARY in-memory store (lib/memoryStore.ts).
# Data resets on server restart and is not shared across instances.
# Restore Prisma + Postgres (see git history) before real users rely on it.
