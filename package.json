{
  "name": "reset",
  "version": "1.0.0",
  "private": true,
  "description": "RESET — A calm place to pause, breathe, and reset — no judgment.",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "db:generate": "npm run db:generate --prefix backend",
    "db:push": "npm run db:push --prefix backend",
    "db:migrate": "npm run db:migrate --prefix backend",
    "db:studio": "npm run db:studio --prefix backend",
    "build:backend": "npm run build --prefix backend",
    "build:frontend": "npm run build --prefix frontend",
    "build": "npm run build:frontend",
    "vercel-build": "npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "prisma": "^5.22.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
