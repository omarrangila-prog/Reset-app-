{
  "name": "reset",
  "version": "1.0.0",
  "private": true,
  "description": "RESET — A calm place to pause, breathe, and reset — no judgment.",
  "scripts": {
    "install:all": "npm install --prefix frontend",
    "dev": "npm run dev --prefix frontend",
    "db:generate": "npm run prisma:generate --prefix frontend",
    "db:migrate": "prisma migrate deploy --schema=frontend/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=frontend/prisma/schema.prisma",
    "build": "npm run build --prefix frontend",
    "vercel-build": "npm run build"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
